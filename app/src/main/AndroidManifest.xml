<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.ttd.jipu">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/logo_jipu"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity android:name="com.ttd.jipu.ui.NavigationActivity" android:theme="@style/NavigationTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name="com.ttd.jipu.ui.GameTableActivity"></activity>

        <activity android:name="com.ttd.jipu.ui.SelectionActivity"/>
    </application>

</manifest>